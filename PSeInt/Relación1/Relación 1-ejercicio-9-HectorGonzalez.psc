Algoritmo Ejercicio9_Descuento
	// DATOS DE ENTRADA Precio de la compra
	// DATOS DE SALIDA: Precio final
	// Descripción: Solicita el precio de la compra y devuelve el precio final mediante una división
	Definir Precio_compra, Precio_final Como Real
    Escribir "Escribe el precio de la compra: "
    Leer Precio_compra
    
    Precio_Final= Precio_compra * 0.85
    Escribir "Total con 15% de descuento: ", Precio_Final

FinAlgoritmo
